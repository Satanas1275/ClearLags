{
  "schemaVersion": 1,
  "id": "clearlags",
  "version": "${version}",
  "name": "ClearLags",
  "description": "Periodically clears dropped items with a configurable timer, warning, and optional HUD countdown overlay.",
  "authors": ["Satanas1275"],
  "contact": {
    "issues": "https://github.com/Satanas1275/ClearLags/issues",
    "sources": "https://github.com/Satanas1275/ClearLags/"
  },
  "license": "CC-BY-NC-4.0",
  "icon": "icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["com.clearlags.ClearLags"],
    "client": ["com.clearlags.ClearLagsClient"]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": ">=${minecraft_version}",
    "fabric-api": ">=${fabric_version}",
    "java": ">=${java_version}"
  }
}
